# Telegram Bot
BOT_TOKEN=your_bot_token_here

# Admin (@RootDev07)
ADMIN_ID=5834939103
ADMIN_USERNAME=@RootDev07

# Payment info
PAYMENT_CARD=8600 1234 5678 9012
PAYMENT_NAME=ROOTDEV
SUPPORT_USERNAME=@RootDev07

# Redis (optional - for Bull queue)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# AI Microservice
AI_SERVICE_URL=http://localhost:8000
# Tezlik: 384=eng tez(1-3s) | 512=tez(2-5s) | 640=o'rta(5-10s) | 1024=sifatli(15-30s)
MAX_SIZE=384
# Model: u2net (eng tez, umumiy)
REMBG_MODEL=u2net

# Storage
STORAGE_PATH=./storage
TEMP_PATH=./storage/temp
OUTPUT_PATH=./storage/output

# Bot settings
MAX_IMAGES_PER_SESSION=20
MAX_FILE_SIZE_MB=10
SESSION_TIMEOUT_MINUTES=30
CLEANUP_INTERVAL_MINUTES=60

# Anti-spam
MAX_REQUESTS_PER_MINUTE=10
MAX_REQUESTS_PER_HOUR=100

# Express API port
API_PORT=3000

# Node environment
NODE_ENV=production

# Proxy (agar Telegram bloklangan bo'lsa)
# PROXY_HOST=127.0.0.1
# PROXY_PORT=8080
